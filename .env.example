# Turso / libSQL
# Локально можно оставить file: (БД в ./.data/local.db, токен не нужен)
TURSO_DATABASE_URL=file:./.data/local.db
TURSO_AUTH_TOKEN=

# Сессии nuxt-auth-utils (≥32 символа)
NUXT_SESSION_PASSWORD=change-me-to-a-long-random-string-min-32-chars

# Учётка администратора
ADMIN_PHONE=+7 (900) 000-0001
ADMIN_PASSWORD=admin123
